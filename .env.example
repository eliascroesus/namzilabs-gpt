# Runtime database URL. Use the Neon pooled hostname (`-pooler`).
DATABASE_URL=postgresql://user:password@host-pooler.neon.tech/database?sslmode=require
# Migration URL. Use the direct Neon hostname (without `-pooler`).
DATABASE_DIRECT_URL=postgresql://user:password@host.neon.tech/database?sslmode=require

APP_URL=http://localhost:3000
APP_ENV=local
ENCRYPTION_KEY_BASE64=

WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=
NEXT_PUBLIC_WORKOS_REDIRECT_URI=https://namzilabs.co/auth/callback

INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_SERVE_ORIGIN=https://namzilabs.co
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://namzilabs.co/api/integrations/google/callback
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=
CALENDLY_WEBHOOK_SIGNING_KEY=
CLOSE_CLIENT_ID=
CLOSE_CLIENT_SECRET=

# Local-only identity. Production refuses to use these values.
DEV_USER_ID=user_local
DEV_ORGANIZATION_ID=00000000-0000-4000-8000-000000000001
DEV_ROLE=owner
